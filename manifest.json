{
  "manifest_version": 3,
  "name": "WriteThatDown - Guide Creator",
  "version": "0.1",
  "description": "Captures mouse clicks and keystrokes to create how-to guides.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"]
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
